# ──────────────────────────────────────────────────────────────────
# Estoque App — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ──────────────────────────────────────────────────────────────────

# Supabase — Public (safe to expose in the browser)
# Found in: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — Server only (NEVER expose to the browser)
# Found in: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — Project reference ID
# Found in: Supabase Dashboard > Project Settings > General
SUPABASE_PROJECT_ID=your-project-ref

# Vercel — Used by scripts/vercel deployment
# Found in: Vercel Dashboard > Settings > General
VERCEL_PROJECT_ID=your-vercel-project-id
VERCEL_ORG_ID=your-vercel-org-id
VERCEL_TOKEN=your-vercel-token

# Supabase CLI access token (used in CI for migrations, not at runtime)
# Found in: supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=your-supabase-access-token

# Supabase Storage — bucket name for imported files
SUPABASE_STORAGE_BUCKET=importacoes

# Tray API — Integration with Tray e-commerce platform
# Found in: Tray Admin > Integrações > API
TRAY_API_URL=https://api.dooki.com.br/v2
TRAY_API_KEY=your-tray-api-key
TRAY_CONSUMER_KEY=your-tray-consumer-key
TRAY_CONSUMER_SECRET=your-tray-consumer-secret
TRAY_STORE_ID=your-tray-store-id
